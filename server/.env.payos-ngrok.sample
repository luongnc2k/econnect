# File env mẫu của EConnect để test payOS thật từ máy local thông qua ngrok.
# Hãy copy file này thành `server/.env` khi bạn muốn dùng payment link thật của payOS
# và xử lý webhook/return thật mà chưa cần deploy backend lên VPS.
#
# Cách dùng khuyến nghị:
# 1. Khởi động backend local ở cổng 8000
# 2. Chạy `ngrok http 8000`
# 3. Thay CẢ HAI URL bên dưới bằng URL HTTPS thật do ngrok cấp
# 4. Khởi động lại backend sau khi sửa `.env`
# 5. Gọi `POST /payments/providers/payos/confirm-webhook` với quyền admin
# 6. Chạy client và test thanh toán như bình thường
#
# Lưu ý quan trọng:
# - Flutter app vẫn nên gọi backend local bằng `SERVER_URL`; không cần trỏ toàn bộ app qua `ngrok`
# - `PAYMENT_PUBLIC_BASE_URL` phải là URL HTTPS public
# - `SERVER_PUBLIC_URL` nên trùng với URL HTTPS public đó để đồng nhất
# - Giữ PAYMENT_GATEWAY_MODE=payos
# - Đặt PAYOS_MOCK_MODE=false
# - Khuyến nghị bắt đầu với `PAYOS_PAYOUT_MOCK_MODE=true` và chỉ đổi sang `false`
#   khi bạn thật sự muốn test payout thật
# - `ngrok` chỉ giúp payOS callback về local. Các API payout thật như verify tài khoản,
#   balance, create payout, sync payout vẫn đi ra từ IP public outbound của backend.
# - Nếu đặt `PAYOS_PAYOUT_MOCK_MODE=false`, hãy thêm IP public outbound đó vào
#   `my.payos.vn > Kênh chuyển tiền > Quản lý IP`, nếu không payOS sẽ trả lỗi
#   `Địa chỉ IP không được phép truy cập hệ thống`.
# - Nếu test bằng `docker/compose.dev.yml` mặc định của repo, PostgreSQL local nằm ở `localhost:5433`

# Cơ sở dữ liệu
DATABASE_URL=postgresql+psycopg2://postgres:123456a%40@localhost:5433/econnectdb

# Xác thực
# Hãy thay toàn bộ secret mẫu trước khi dùng trong môi trường có nhiều người cùng truy cập.
JWT_SECRET=change_this_to_at_least_32_characters_long_secret
JWT_EXPIRE_MINUTES=10080
ALLOW_LEGACY_JWT_SECRET=false
ADMIN_CREATE_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImIyMjY2ZWJmLTNjMTEtNDAxYS05YTFkLTRjMTQ3ZWExOTI5MyIsInJvbGUiOiJhZG1pbiIsImlhdCI6MTc3NDM3MzkwOCwiZXhwIjoxNzc0OTc4NzA4fQ.BNRO0ahbrOiMibdtigTDoH_dVXraqCm31XVgYNaxkwQ
JOB_SECRET=change_this_scheduler_secret

# Khởi động ứng dụng / truy cập API
# Hãy giữ development vì backend vẫn đang chạy trên máy local của bạn.
APP_ENV=development
STRICT_STARTUP_VALIDATION=false
AUTO_INIT_SCHEMA=true
INTERNAL_JOB_RUNNER_ENABLED=true
INTERNAL_JOB_RUNNER_INTERVAL_SECONDS=60
ALLOW_DIRECT_CLASS_CREATION=false

# Vẫn cần các origin local vì Flutter app thường chạy ở máy local.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_ORIGIN_REGEX=

# URL public của backend
# Hãy thay placeholder bằng đúng URL HTTPS mà ngrok cấp cho bạn.
# Ví dụ: https://abc123.ngrok-free.app
SERVER_PUBLIC_URL=https://unwistfully-unsanctimonious-rick.ngrok-free.dev
PAYMENT_PUBLIC_BASE_URL=https://unwistfully-unsanctimonious-rick.ngrok-free.dev
# URL mà client thực tế dùng để tải /static/... khi backend fallback về local uploads.
# Hãy đổi giá trị này theo đúng SERVER_URL phía client đang dùng:
# - http://127.0.0.1:8000 khi app/web chạy cùng máy
# - http://10.0.2.2:8000 với Android emulator
# - http://<LAN_IP_CUA_MAY_DEV>:8000 với máy thật cùng mạng
STATIC_PUBLIC_URL=http://127.0.0.1:8000

# Upload / lưu trữ
LOCAL_UPLOAD_ROOT=uploads
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# Cổng thanh toán
# Cấu hình này sẽ bật payOS thật thay cho mock checkout nội bộ.
PAYMENT_GATEWAY_MODE=payos

# Credential payment của payOS
# Hãy điền credential thật do payOS cung cấp.
PAYOS_CLIENT_ID=90211188-de53-46c1-aba3-154a725c6be4
PAYOS_API_KEY=d43b5775-43de-46e0-982c-8a30795f18b1
PAYOS_CHECKSUM_KEY=6c44ba84be87974ae1847ace6acdd01df804d72727484f419bd213282772f07d
PAYOS_PARTNER_CODE=

# Tùy chọn ghi đè client payment payOS
PAYOS_BASE_URL=https://api-merchant.payos.vn
PAYOS_TIMEOUT=60
PAYOS_MAX_RETRIES=2
PAYOS_MOCK_MODE=false

# Credential payout của payOS
# Payment va payout dung bo credential rieng.
# Khi bat payout that, hay dien day du PAYOS_PAYOUT_CLIENT_ID, PAYOS_PAYOUT_API_KEY,
# PAYOS_PAYOUT_CHECKSUM_KEY. PAYOS_PAYOUT_PARTNER_CODE la tuy chon neu payout can partner code rieng.
PAYOS_PAYOUT_CLIENT_ID=
PAYOS_PAYOUT_API_KEY=
PAYOS_PAYOUT_CHECKSUM_KEY=
PAYOS_PAYOUT_PARTNER_CODE=

# Tùy chọn ghi đè client payout payOS
PAYOS_PAYOUT_BASE_URL=https://api-merchant.payos.vn
PAYOS_PAYOUT_TIMEOUT=60
PAYOS_PAYOUT_MAX_RETRIES=2
# Giữ `true` nếu bạn đang chạy local/ngrok và chưa allowlist IP public outbound của backend
# trong `my.payos.vn > Kênh chuyển tiền > Quản lý IP`.
PAYOS_PAYOUT_MOCK_MODE=true
# Bật `true` nếu máy local ưu tiên IPv6 nhưng bạn mới allowlist IPv4 cho payout payOS.
PAYOS_PAYOUT_FORCE_IPV4=false

# Firebase Cloud Messaging (tùy chọn)
# Chỉ cần điền một trong hai biến này nếu bạn muốn backend thử gửi FCM push notification.
FCM_SERVICE_ACCOUNT_PATH=
FCM_SERVICE_ACCOUNT_JSON=
