# Database
DATABASE_URL=postgresql+psycopg2://postgres:123456a%40@localhost:5432/econnectdb

# Auth
JWT_SECRET=change_this_to_at_least_32_characters_long_secret
JWT_EXPIRE_MINUTES=10080
ALLOW_LEGACY_JWT_SECRET=false
ADMIN_CREATE_SECRET=change_this_admin_bootstrap_secret
JOB_SECRET=change_this_scheduler_secret

# App startup / API access
APP_ENV=development
STRICT_STARTUP_VALIDATION=false
AUTO_INIT_SCHEMA=true
ALLOW_DIRECT_CLASS_CREATION=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
# Optional. In development, backend will already allow localhost/127.0.0.1 on any port by default.
CORS_ALLOW_ORIGIN_REGEX=

# Public backend URL
SERVER_PUBLIC_URL=http://127.0.0.1:8000
PAYMENT_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Upload / storage
LOCAL_UPLOAD_ROOT=uploads
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# Payment gateway
# Use `mock` for local development without public webhook/return URLs.
PAYMENT_GATEWAY_MODE=mock

# payOS payment credentials
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_PARTNER_CODE=

# Optional payOS payment client overrides
PAYOS_BASE_URL=https://api-merchant.payos.vn
PAYOS_TIMEOUT=60
PAYOS_MAX_RETRIES=2
PAYOS_MOCK_MODE=true

# payOS payout credentials
# If left blank, payout flow falls back to PAYOS_* above.
PAYOS_PAYOUT_CLIENT_ID=
PAYOS_PAYOUT_API_KEY=
PAYOS_PAYOUT_CHECKSUM_KEY=
PAYOS_PAYOUT_PARTNER_CODE=

# Optional payOS payout client overrides
PAYOS_PAYOUT_BASE_URL=https://api-merchant.payos.vn
PAYOS_PAYOUT_TIMEOUT=60
PAYOS_PAYOUT_MAX_RETRIES=2
PAYOS_PAYOUT_MOCK_MODE=true

# Firebase Cloud Messaging (optional)
# Khi backend có service account hop le, moi notification moi tao se duoc thu gui FCM
# den cac device token dang active cua user.
FCM_SERVICE_ACCOUNT_PATH=
FCM_SERVICE_ACCOUNT_JSON=
